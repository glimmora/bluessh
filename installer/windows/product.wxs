<?xml version="1.0" encoding="UTF-8"?>
<!--
  BlueSSH Windows Installer (WiX v5)
  Produces: BlueSSH-<version>-x64.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="BlueSSH"
           Manufacturer="BlueSSH Project"
           Version="1.0.0.0"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           Scope="perMachine">

    <SummaryInformation Description="BlueSSH - High-performance remote access client" />

    <!-- Upgrade logic -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of BlueSSH is already installed."
                  Schedule="afterInstallInitialize" />

    <!-- UI -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- Features -->
    <Feature Id="MainFeature" Title="BlueSSH" Level="1">
      <ComponentGroupRef Id="EngineComponents" />
      <ComponentGroupRef Id="UIComponents" />
      <ComponentGroupRef Id="ShortcutComponents" />
      <ComponentRef Id="PathEnv" />
    </Feature>

    <!-- Installation directory -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="BlueSSH">
        <Directory Id="EngineDir" Name="engine" />
        <Directory Id="UiDir" Name="ui" />
      </Directory>
    </StandardDirectory>

    <!-- Start menu shortcuts -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuDir" Name="BlueSSH">
        <Component Id="ShortcutComponents" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
          <Shortcut Id="AppShortcut"
                    Name="BlueSSH"
                    Target="[INSTALLFOLDER]ui\bluessh.exe"
                    WorkingDirectory="INSTALLFOLDER"
                    Icon="BlueSSH.ico"
                    Description="High-performance remote access client" />
          <RemoveFolder Id="RemoveStartMenuDir" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\BlueSSH"
                         Name="ShortcutInstalled" Type="integer"
                         Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- PATH environment variable -->
    <Component Id="PathEnv" Directory="INSTALLFOLDER"
               Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
      <Environment Id="Path"
                   Name="PATH"
                   Value="[INSTALLFOLDER]ui"
                   Permanent="no"
                   Part="last"
                   Action="set"
                   System="yes" />
    </Component>

    <!-- Application icon -->
    <Icon Id="BlueSSH.ico" SourceFile="assets\bluessh.ico" />

  </Package>
</Wix>

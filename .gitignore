# ═══════════════════════════════════════════════════════════════════════
#  .gitignore — BlueSSH Multi-Platform Project
#  Covers: Rust, Flutter (Android, Linux, Windows), Kotlin
# ═══════════════════════════════════════════════════════════════════════

# ─── OS Artifacts ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Editor / IDE ───────────────────────────────────────────────────

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
*.code-workspace

# IntelliJ / JetBrains (Android Studio, CLion, RustRover)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
.*.sw[a-z]
.netrwhist
Session.vim

# Emacs
*~
\#*\#
.\#*
.dir-locals.el

# Sublime Text
*.sublime-project
*.sublime-workspace

# ─── Rust ───────────────────────────────────────────────────────────

# Cargo build output
engine/target/

# Rust build artifacts
*.rs.bk
*.rlib
*.o
*.a
*.d

# cargo-tarpaulin coverage
tarpaulin-report.html
cobertura.xml

# cargo-audit
advisory-db/

# ─── Flutter ────────────────────────────────────────────────────────

# Flutter build output (all platforms)
ui/build/

# Flutter tooling
.flutter-plugins
.flutter-plugins-dependencies
.packages
.dart_tool/
.pub-cache/
.pub/

# ─── Native Library Build Outputs ───────────────────────────────────
# These are produced by cargo and cargo-ndk — do not commit.
# The Rust source in engine/ is the source of truth.
*.so
*.dll
*.dylib

# JNI libs for Android (rebuilt by build_android.sh)
ui/android/app/src/main/jniLibs/

# Desktop libs (rebuilt by build_ubuntu.sh)
ui/linux/lib/

# ─── Distribution Artifacts ─────────────────────────────────────────
# Release binaries produced by build scripts — do not commit.
dist/

# ─── Android ───────────────────────────────────────────────────────

# Gradle
.gradle/
ui/android/.gradle/
ui/android/app/.gradle/

# Android local config (SDK path, etc.)
local.properties

# Signing keys (NEVER commit)
*.jks
*.keystore
keystore.properties

# Google services config
google-services.json

# NDK build intermediates
obj/
.cxx/

# ─── Linux (Ubuntu) ───────────────────────────────────────────────

# CMake
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
compile_commands.json

# Snap packaging
snap/.snapcraft/
*.snap

# Debian packaging intermediates
.deb-build/
debian/.debhelper/
debian/bluessh/
debian/files
debian/*.debhelper.log
debian/*.substvars

# ─── iOS / macOS (future) ─────────────────────────────────────────

ios/Pods/
ios/Podfile.lock
ios/build/
macos/Podfile.lock
macos/build/
DerivedData/
Carthage/Build/
Carthage/Checkouts/
.swiftpm/
Package.resolved
*.dSYM.zip
*.dSYM

# ─── Environment / Secrets ─────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.pem
*.p12
*.pfx

# ─── Testing ───────────────────────────────────────────────────────
test-results/
junit.xml
__snapshots__/
playwright-report/
coverage/
*.lcov
.nyc_output/

# ─── Temporary / Cache ────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
.cache/

# ─── Logs ─────────────────────────────────────────────────────────
*.log
logs/

# Watchdog runtime artifacts
scripts/watchdog/logs/
scripts/watchdog/*.pid

# ─── Docker ───────────────────────────────────────────────────────
docker-compose.override.yml
.docker/

# ─── Terraform / IaC ─────────────────────────────────────────────
*.tfstate
*.tfstate.*
.terraform/

# ─── Miscellaneous ────────────────────────────────────────────────
*.pid
*.seed
*.pid.lock
lib-cov/
pids/
results/
out/

# Xcode (future iOS/macOS support)
xcuserdata/
*.xcscmblueprint
*.xccheckout
*.moved-aside
*.hmap
*.ipa
